<div class="cart-page container">
  {% if cart.item_count == 0 %}
    <div class="cart-empty-page">
      <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width=".6"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <h2>Your cart is empty</h2>
      <p>Looks like you haven't added anything yet.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Shop Now</a>
      <a href="{{ routes.root_url }}" class="btn btn--ghost">← Back to Home</a>
    </div>
  {% else %}
    <h1 class="cart-page-title">Your Cart</h1>
    <div class="cart-page-layout">
      <div class="cart-page-items">
        <div class="cart-table-head">
          <span>Product</span><span>Price</span><span>Quantity</span><span>Total</span>
        </div>
        <div class="cart-page-items-inner">
          {% for item in cart.items %}
            <div class="cart-row">
              <div class="cart-row-product">
                <div class="cart-row-img">
                  <a href="{{ item.url }}">
                    {% if item.image %}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" loading="lazy">{% endif %}
                  </a>
                </div>
                <div>
                  <div class="cart-row-name"><a href="{{ item.url }}">{{ item.product.title }}</a></div>
                  {% if item.variant.title != 'Default Title' %}<div class="cart-row-variant">{{ item.variant.title }}</div>{% endif %}
                  <button class="cart-row-remove" data-key="{{ item.key }}" onclick="removeCartItem('{{ item.key }}').then(()=>location.reload())">Remove</button>
                </div>
              </div>
              <div class="cart-row-price">{{ item.price | money }}</div>
              <div class="cart-row-qty">
                <button class="cart-qty-btn" data-key="{{ item.key }}" data-action="dec" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }}).then(()=>location.reload())">−</button>
                <input class="cart-qty-num" type="number" value="{{ item.quantity }}" readonly>
                <button class="cart-qty-btn" data-key="{{ item.key }}" data-action="inc" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }}).then(()=>location.reload())">+</button>
              </div>
              <div class="cart-row-total">{{ item.final_line_price | money }}</div>
            </div>
          {% endfor %}
        </div>
        <div style="margin-top:2rem">
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost">← Continue Shopping</a>
        </div>
      </div>
      <!-- Summary -->
      <div class="cart-summary">
        <div class="cart-summary-title">Order Summary</div>
        <div class="cart-summary-row"><span>Subtotal ({{ cart.item_count }} items)</span><span>{{ cart.total_price | money }}</span></div>
        <div class="cart-summary-row"><span>Shipping</span><span>{% if cart.total_price >= 99900 %}FREE{% else %}Calculated at checkout{% endif %}</span></div>
        <div class="cart-summary-row"><span>Taxes</span><span>Included</span></div>
        <div class="cart-summary-row total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <div class="cart-promo">
          <div class="cart-summary-row" style="margin-bottom:.5rem">
            <span style="font-family:var(--font-mono);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--grey-400)">Promo Code</span>
          </div>
          <div class="cart-promo-form">
            <input class="cart-promo-input" type="text" placeholder="Enter promo code">
            <button class="btn btn--ghost btn--sm" type="button" onclick="showToast('Promo code', 'Discount codes apply at checkout.','info')">Apply</button>
          </div>
        </div>
        <div class="cart-notes">
          <label for="cart-note">Order Note</label>
          <textarea id="cart-note" class="cart-notes textarea form-control form-textarea" placeholder="Special instructions for your order..." style="margin-top:.5rem"></textarea>
        </div>
        <div class="cart-summary-actions">
          <a href="/checkout" class="btn btn--primary btn--full">Checkout →</a>
          <a href="{{ routes.cart_url }}" class="btn btn--ghost btn--full" style="font-size:.85rem">View Cart Page</a>
        </div>
        <div class="cart-shipping-info">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Free shipping on orders above ₹999
        </div>
      </div>
    </div>
  {% endif %}
</div>
