<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#0A0A0A">
  <link rel="canonical" href="{{ canonical_url }}">
  {% if settings.favicon %}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
  {% endif %}
  <title>
    {{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="uz-body">
  <a class="skip-link" href="#MainContent">Skip to content</a>
  {% section 'header' %}
  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  <div id="uz-cart-drawer" class="cart-drawer" aria-hidden="true">
    <div class="cart-drawer__overlay"></div>
    <div class="cart-drawer__panel">
      <div class="cart-drawer__header">
        <span>Your Cart (<span id="cart-count">0</span>)</span>
        <button class="cart-drawer__close" aria-label="Close cart">&#x2715;</button>
      </div>
      <div class="cart-drawer__body" id="cart-drawer-body">
        <p class="cart-empty">Your cart is empty.</p>
      </div>
      <div class="cart-drawer__footer">
        <a href="/cart" class="btn btn--primary btn--full">Checkout</a>
      </div>
    </div>
  </div>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
