<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-logo">URBAN<span>ZOLE</span></div>
        <p class="footer-brand-text">{{ section.settings.tagline | default: "Urban-engineered footwear for streets that never sleep. Walk with intention. Live without limits." }}</p>
        <div class="footer-socials">
          {% if section.settings.instagram != blank %}<a href="{{ section.settings.instagram }}" class="footer-social" target="_blank" rel="noopener" aria-label="Instagram">IG</a>{% endif %}
          {% if section.settings.facebook != blank %}<a href="{{ section.settings.facebook }}" class="footer-social" target="_blank" rel="noopener" aria-label="Facebook">FB</a>{% endif %}
          {% if section.settings.twitter != blank %}<a href="{{ section.settings.twitter }}" class="footer-social" target="_blank" rel="noopener" aria-label="Twitter">𝕏</a>{% endif %}
          {% if section.settings.youtube != blank %}<a href="{{ section.settings.youtube }}" class="footer-social" target="_blank" rel="noopener" aria-label="YouTube">YT</a>{% endif %}
        </div>
      </div>
      {% for block in section.blocks %}{% if block.type == 'menu' %}
        <div {{ block.shopify_attributes }}>
          <div class="footer-col-title">{{ block.settings.title }}</div>
          <ul class="footer-links">
            {% for link in linklists[block.settings.menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}{% endfor %}
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-pay">
        <span class="pay-badge">UPI</span>
        <span class="pay-badge">Razorpay</span>
        <span class="pay-badge">Visa</span>
        <span class="pay-badge">Mastercard</span>
        <span class="pay-badge">COD</span>
      </div>
      <div class="footer-legal">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/policies/refund-policy">Returns</a>
        <a href="/policies/shipping-policy">Shipping</a>
      </div>
    </div>
  </div>
</footer>
{% schema %}
{
  "name": "Footer",
  "settings": [
    {"type":"textarea","id":"tagline","label":"Tagline"},
    {"type":"url","id":"instagram","label":"Instagram"},
    {"type":"url","id":"facebook","label":"Facebook"},
    {"type":"url","id":"twitter","label":"Twitter / X"},
    {"type":"url","id":"youtube","label":"YouTube"}
  ],
  "blocks":[{"type":"menu","name":"Menu Column","settings":[
    {"type":"text","id":"title","label":"Heading","default":"Shop"},
    {"type":"link_list","id":"menu","label":"Menu","default":"footer"}
  ]}],
  "presets":[{"name":"Footer","blocks":[
    {"type":"menu","settings":{"title":"Shop"}},
    {"type":"menu","settings":{"title":"Help"}},
    {"type":"menu","settings":{"title":"Company"}}
  ]}]
}
{% endschema %}
