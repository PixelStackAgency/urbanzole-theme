{% comment %} Footer Section — UrbanZole {% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <div class="footer-brand__logo">URBAN<span>ZOLE</span></div>
        <p class="footer-brand__tagline">
          {{ section.settings.tagline | default: "Urban-engineered footwear for streets that never sleep. Walk with intention. Live without limits." }}
        </p>
        <div class="footer-socials">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">IG</a>
          {% endif %}
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener">FB</a>
          {% endif %}
          {% if section.settings.twitter_url != blank %}
            <a href="{{ section.settings.twitter_url }}" aria-label="Twitter / X" target="_blank" rel="noopener">𝕏</a>
          {% endif %}
          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" aria-label="YouTube" target="_blank" rel="noopener">YT</a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'link_list' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h3 class="footer-col__title">{{ block.settings.heading }}</h3>
            <ul class="footer-col__links" role="list">
              {% for link in linklists[block.settings.menu].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}

    </div>

    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} — All Rights Reserved
      </p>
      <div class="footer-bottom__payments">
        <span class="payment-icon">UPI</span>
        <span class="payment-icon">Razorpay</span>
        <span class="payment-icon">Visa</span>
        <span class="payment-icon">MC</span>
        <span class="payment-icon">COD</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Brand tagline" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "twitter_url", "label": "Twitter / X URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quick Links" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Shop" } },
      { "type": "link_list", "settings": { "heading": "Support" } },
      { "type": "link_list", "settings": { "heading": "Company" } }
    ]
  }]
}
{% endschema %}
