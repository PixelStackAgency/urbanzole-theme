{% if section.settings.show and section.settings.text != blank %}
<div class="announcement-bar">
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {% else %}
    {{ section.settings.text }}
  {% endif %}
</div>
{% endif %}
{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"checkbox","id":"show","label":"Show bar","default":true},
    {"type":"text","id":"text","label":"Message","default":"Free Shipping on orders above ₹999 — COD Available across India"},
    {"type":"url","id":"link","label":"Link (optional)"}
  ]
}
{% endschema %}
