<section class="newsletter-section">
  <div class="container">
    <div class="t-label" style="justify-content:center;margin-bottom:.75rem">{{ section.settings.eyebrow | default: "Stay In The Loop" }}</div>
    <h2 class="newsletter-title reveal">{{ section.settings.line1 | default: "DROP" }} <span>{{ section.settings.line2 | default: "ALERTS" }}</span><br>{{ section.settings.line3 | default: "FIRST." }}</h2>
    <p class="newsletter-sub reveal d1">{{ section.settings.sub | default: "Early access to new drops, limited collabs & member-only deals." }}</p>
    {% form 'customer', class: 'newsletter-form reveal d2' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input class="newsletter-input" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}" required autocomplete="email">
      <button type="submit" class="btn btn--primary">{{ section.settings.btn | default: "Subscribe" }}</button>
    {% endform %}
    <p class="newsletter-note reveal d3">No spam. Unsubscribe anytime.</p>
  </div>
</section>
{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Stay In The Loop"},
    {"type":"text","id":"line1","label":"Title line 1","default":"DROP"},
    {"type":"text","id":"line2","label":"Title line 2 (orange)","default":"ALERTS"},
    {"type":"text","id":"line3","label":"Title line 3","default":"FIRST."},
    {"type":"text","id":"sub","label":"Subtitle"},
    {"type":"text","id":"placeholder","label":"Placeholder","default":"your@email.com"},
    {"type":"text","id":"btn","label":"Button","default":"Subscribe"}
  ],
  "presets":[{"name":"Newsletter"}]
}
{% endschema %}
