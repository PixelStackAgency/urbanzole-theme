<section class="hero">
  <div class="hero-content">
    <div class="t-label hero-eyebrow reveal">{{ section.settings.eyebrow | default: "New Collection 2025" }}</div>
    <h1 class="hero-title reveal d1">
      {{ section.settings.line1 | default: "WALK" }}<br>
      <span class="hero-title-accent">{{ section.settings.line2 | default: "LOUD." }}</span>
      {{ section.settings.line3 | default: "LIVE" }}<br>
      {{ section.settings.line4 | default: "BOLD." }}
    </h1>
    <p class="hero-sub reveal d2">{{ section.settings.subtitle | default: "Urban-engineered footwear built for streets that never sleep. Every step is a statement." }}</p>
    <div class="hero-ctas reveal d3">
      {% if section.settings.btn1_label != blank %}
        <a href="{{ section.settings.btn1_url | default: routes.all_products_collection_url }}" class="btn btn--primary">
          {{ section.settings.btn1_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% endif %}
      {% if section.settings.btn2_label != blank %}
        <a href="{{ section.settings.btn2_url | default: '#' }}" class="btn btn--ghost">{{ section.settings.btn2_label }}</a>
      {% endif %}
    </div>
    <div class="hero-scroll"><div class="hero-scroll-line"></div><span class="hero-scroll-text">Scroll</span></div>
  </div>
  <div class="hero-media">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 1200 }}"
           srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
           sizes="50vw" alt="{{ section.settings.image.alt | default: 'UrbanZole' }}" loading="eager" fetchpriority="high">
    {% else %}
      <div style="width:100%;height:100%;background:linear-gradient(160deg,#1a0a00 0%,#2a1500 60%,#0a0a0a 100%);display:flex;align-items:center;justify-content:center">
        <span style="font-family:var(--font-display);font-size:18vw;color:rgba(255,255,255,.03);letter-spacing:.1em">UZ</span>
      </div>
    {% endif %}
    <div class="hero-media-overlay"></div>
    <div class="hero-tag">{{ section.settings.tag | default: "SS25 / Vol. 01" }}</div>
  </div>
</section>
{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"New Collection 2025"},
    {"type":"text","id":"line1","label":"Title line 1","default":"WALK"},
    {"type":"text","id":"line2","label":"Title line 2 (accent)","default":"LOUD."},
    {"type":"text","id":"line3","label":"Title line 3","default":"LIVE"},
    {"type":"text","id":"line4","label":"Title line 4","default":"BOLD."},
    {"type":"textarea","id":"subtitle","label":"Subtitle"},
    {"type":"text","id":"btn1_label","label":"Primary button label","default":"Shop Collection"},
    {"type":"url","id":"btn1_url","label":"Primary button URL"},
    {"type":"text","id":"btn2_label","label":"Secondary button label","default":"View Lookbook"},
    {"type":"url","id":"btn2_url","label":"Secondary button URL"},
    {"type":"image_picker","id":"image","label":"Hero image"},
    {"type":"text","id":"tag","label":"Side tag text","default":"SS25 / Vol. 01"}
  ],
  "presets":[{"name":"Hero Banner"}]
}
{% endschema %}
