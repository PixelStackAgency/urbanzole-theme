<section class="section">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="t-label reveal">{{ section.settings.eyebrow | default: "Reviews" }}</div>
        <h2 class="section-title reveal d1">{{ section.settings.title | default: "WHAT THEY SAY" }}</h2>
      </div>
    </div>
    <div class="testimonials-track" role="list">
      {% for block in section.blocks %}{% if block.type == 'review' %}
        <div class="testi-card reveal" role="listitem" {{ block.shopify_attributes }}>
          <div class="testi-stars">{% for i in (1..block.settings.rating) %}★{% endfor %}{% assign r = 5 | minus: block.settings.rating %}{% for i in (1..r) %}☆{% endfor %}</div>
          <p class="testi-text">"{{ block.settings.text }}"</p>
          <div class="testi-author">
            <div class="testi-avatar">
              {% if block.settings.avatar != blank %}<img src="{{ block.settings.avatar | image_url: width: 100 }}" alt="{{ block.settings.name }}" loading="lazy">
              {% else %}{{ block.settings.name | slice: 0 }}{% endif %}
            </div>
            <div>
              <div class="testi-name">{{ block.settings.name }}</div>
              <div class="testi-meta">{{ block.settings.meta | default: "Verified Buyer" }}</div>
            </div>
          </div>
        </div>
      {% endif %}{% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Reviews"},
    {"type":"text","id":"title","label":"Title","default":"WHAT THEY SAY"}
  ],
  "blocks":[{"type":"review","name":"Review","settings":[
    {"type":"range","id":"rating","label":"Rating","min":1,"max":5,"step":1,"default":5},
    {"type":"textarea","id":"text","label":"Review text","default":"Best shoes I've ever worn. UrbanZole quality is unmatched."},
    {"type":"text","id":"name","label":"Name","default":"Arjun M."},
    {"type":"text","id":"meta","label":"Meta","default":"Verified Buyer"},
    {"type":"image_picker","id":"avatar","label":"Avatar"}
  ]}],
  "presets":[{"name":"Testimonials","blocks":[
    {"type":"review","settings":{"name":"Arjun M.","text":"Best urban footwear I've owned. Built tough, looks premium every time.","rating":5}},
    {"type":"review","settings":{"name":"Priya K.","text":"Wore them to 3 concerts, still fresh. 100% repeat buyer here!","rating":5}},
    {"type":"review","settings":{"name":"Rahul D.","text":"Delivered in 2 days. Fit is perfect. The sole grip is insane for the price.","rating":5}},
    {"type":"review","settings":{"name":"Sneha R.","text":"These slides go with everything. Already ordered 3 pairs. Love this brand.","rating":5}}
  ]}]
}
{% endschema %}
