{% comment %} Categories Grid Section {% endcomment %}

<section class="categories">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="section-header__eyebrow label">{{ section.settings.eyebrow | default: "Browse" }}</div>
        <h2 class="display-lg reveal">{{ section.settings.title | default: "SHOP BY STYLE" }}</h2>
      </div>
    </div>

    <div class="categories-grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <div class="category-card {% if forloop.first %}category-card--tall{% endif %} reveal reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                class="category-card__img"
                src="{{ block.settings.image | image_url: width: 700 }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
              >
            {% else %}
              <div style="width:100%;height:100%;background:var(--grey-mid);min-height:280px"></div>
            {% endif %}
            <div class="category-card__content">
              <div class="category-card__label-tag">{{ block.settings.tag | default: "Collection" }}</div>
              <h3 class="category-card__title">{{ block.settings.title }}</h3>
              <a href="{{ block.settings.url }}" class="category-card__link">
                Explore
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse" },
    { "type": "text", "id": "title", "label": "Title", "default": "SHOP BY STYLE" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag text", "default": "Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sneakers" },
        { "type": "url", "id": "url", "label": "Link URL" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [{
    "name": "Categories Grid",
    "blocks": [
      { "type": "category", "settings": { "title": "Sneakers", "tag": "Street Ready" } },
      { "type": "category", "settings": { "title": "Sandals", "tag": "Summer Edit" } },
      { "type": "category", "settings": { "title": "Boots", "tag": "New Season" } },
      { "type": "category", "settings": { "title": "Loafers", "tag": "Premium" } },
      { "type": "category", "settings": { "title": "Slides", "tag": "Casual" } }
    ]
  }]
}
{% endschema %}
