<section class="section">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="t-label reveal">{{ section.settings.eyebrow | default: "Browse" }}</div>
        <h2 class="section-title reveal d1">{{ section.settings.title | default: "SHOP BY STYLE" }}</h2>
      </div>
    </div>
    <div class="categories-grid">
      {% for block in section.blocks %}{% if block.type == 'cat' %}
        <a href="{{ block.settings.url | default: '#' }}" class="cat-card reveal" style="transition-delay:{{ forloop.index0 | times: 0.08 }}s" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.title }}" loading="lazy">
          {% else %}
            <div style="width:100%;height:100%;background:var(--grey-800)"></div>
          {% endif %}
          <div class="cat-info">
            <div class="cat-tag">{{ block.settings.tag | default: "Collection" }}</div>
            <h3 class="cat-name">{{ block.settings.title }}</h3>
            <span class="cat-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      {% endif %}{% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Browse"},
    {"type":"text","id":"title","label":"Title","default":"SHOP BY STYLE"}
  ],
  "blocks":[{"type":"cat","name":"Category","settings":[
    {"type":"text","id":"tag","label":"Tag","default":"Collection"},
    {"type":"text","id":"title","label":"Title","default":"Sneakers"},
    {"type":"url","id":"url","label":"URL"},
    {"type":"image_picker","id":"image","label":"Image"}
  ]}],
  "presets":[{"name":"Categories Grid","blocks":[
    {"type":"cat","settings":{"title":"Sneakers","tag":"Street Ready"}},
    {"type":"cat","settings":{"title":"Sandals","tag":"Summer Edit"}},
    {"type":"cat","settings":{"title":"Boots","tag":"New Season"}},
    {"type":"cat","settings":{"title":"Loafers","tag":"Premium"}},
    {"type":"cat","settings":{"title":"Slides","tag":"Casual"}}
  ]}]
}
{% endschema %}
