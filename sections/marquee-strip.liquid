<div class="marquee" aria-hidden="true">
  <div class="marquee-inner">
    {% assign items = section.settings.text | split: '|' %}
    {% for i in (1..4) %}
      {% for item in items %}
        <span class="marquee-item">{{ item | strip }}<span class="marquee-dot">✦</span></span>
      {% endfor %}
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "Marquee Strip",
  "settings": [{"type":"text","id":"text","label":"Items (separate with |)","default":"Free Shipping ₹999+ | 30-Day Returns | Premium Handcrafted | New Drops Fridays | COD Available"}],
  "presets":[{"name":"Marquee Strip"}]
}
{% endschema %}
