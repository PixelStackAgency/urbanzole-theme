<div class="contact-page">
  <div class="container">
    <div class="contact-hero">
      <div class="t-label reveal">{{ section.settings.eyebrow | default: "Get In Touch" }}</div>
      <h1 class="section-title reveal d1" style="font-size:clamp(3rem,7vw,8rem)">
        {{ section.settings.line1 | default: "TALK TO" }} <span class="text-orange">{{ section.settings.line2 | default: "US." }}</span>
      </h1>
      <p class="contact-hero-sub reveal d2">{{ section.settings.subtitle | default: "We reply within 24 hours. No bots, no scripts — just real people who love shoes as much as you do." }}</p>
    </div>
    <div class="contact-grid">
      <!-- Form -->
      <div class="reveal">
        <div class="contact-form-num">01</div>
        <h2 class="contact-form-title">Send a Message</h2>
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="contact-success">
              <div class="contact-success-icon">✓</div>
              <div class="contact-success-title">Message Received!</div>
              <p class="contact-success-text">We'll get back to you within 24 hours.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div class="contact-error-box">
                <strong>Please fix the following:</strong>
                <ul>{% for error in form.errors %}<li>{{ error | capitalize }} {{ form.errors.messages[error] }}</li>{% endfor %}</ul>
              </div>
            {% endif %}
            <div class="form-grid-2">
              <div class="form-group">
                <label class="form-label" for="contact-name">Name <span class="form-required">*</span></label>
                <input class="form-control" type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" placeholder="Arjun Mehta" required autocomplete="name">
              </div>
              <div class="form-group">
                <label class="form-label" for="contact-email">Email <span class="form-required">*</span></label>
                <input class="form-control" type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" placeholder="arjun@email.com" required autocomplete="email">
              </div>
            </div>
            <div class="form-grid-2">
              <div class="form-group">
                <label class="form-label" for="contact-phone">Phone</label>
                <input class="form-control" type="tel" id="contact-phone" name="contact[phone]" placeholder="+91 98765 43210" autocomplete="tel">
              </div>
              <div class="form-group">
                <label class="form-label" for="contact-subject">Subject <span class="form-required">*</span></label>
                <select class="form-control form-select" id="contact-subject" name="contact[subject]" required>
                  <option value="" disabled selected>Select a topic</option>
                  <option value="Order Issue">Order Issue</option>
                  <option value="Return / Refund">Return / Refund</option>
                  <option value="Size Query">Size Query</option>
                  <option value="Product Query">Product Query</option>
                  <option value="Wholesale">Wholesale / B2B</option>
                  <option value="Collaboration">Collaboration</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-order">Order Number <span class="form-optional">(if applicable)</span></label>
              <input class="form-control" type="text" id="contact-order" name="contact[order]" placeholder="#UZ-00123">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-msg">Message <span class="form-required">*</span></label>
              <textarea class="form-control form-textarea" id="contact-msg" name="contact[body]" rows="6" placeholder="Tell us how we can help you..." required>{{ form.body }}</textarea>
            </div>
            <button type="submit" class="btn btn--primary">Send Message <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          {% endif %}
        {% endform %}
      </div>
      <!-- Info -->
      <div class="reveal d2">
        <div class="contact-form-num">02</div>
        <h2 class="contact-form-title">Contact Details</h2>
        <div class="contact-info-cards">
          {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" class="contact-info-card">
            <div class="cic-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><div class="cic-label">Email</div><div class="cic-value">{{ section.settings.email }}</div><div class="cic-note">Response within 24 hours</div></div>
          </a>
          {% endif %}
          {% if section.settings.phone != blank %}
          <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-info-card">
            <div class="cic-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.59 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><div class="cic-label">Phone</div><div class="cic-value">{{ section.settings.phone }}</div><div class="cic-note">{{ section.settings.phone_hours | default: "Mon–Sat, 10am–7pm IST" }}</div></div>
          </a>
          {% endif %}
          {% if section.settings.whatsapp != blank %}
          <a href="https://wa.me/{{ section.settings.whatsapp | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener" class="contact-info-card contact-info-card--wa">
            <div class="cic-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg></div>
            <div><div class="cic-label">WhatsApp</div><div class="cic-value">Chat Instantly</div><div class="cic-note">Fastest response</div></div>
          </a>
          {% endif %}
          {% if section.settings.address != blank %}
          <div class="contact-info-card">
            <div class="cic-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><div class="cic-label">Address</div><div class="cic-value">{{ section.settings.address }}</div></div>
          </div>
          {% endif %}
        </div>
        <div class="contact-hours-card">
          <div class="hours-title">Business Hours</div>
          <div class="hours-row"><span>Monday – Friday</span><span>{{ section.settings.h_weekday | default: "10:00 AM – 7:00 PM" }}</span></div>
          <div class="hours-row"><span>Saturday</span><span>{{ section.settings.h_sat | default: "10:00 AM – 5:00 PM" }}</span></div>
          <div class="hours-row"><span>Sunday</span><span class="hours-closed">{{ section.settings.h_sun | default: "Closed" }}</span></div>
        </div>
        <div class="contact-faq-title">Quick Answers</div>
        <details class="faq-item"><summary class="faq-q">How long does delivery take?</summary><p class="faq-a">Standard delivery takes 3–5 business days across India. Express (1–2 days) available at checkout for most pincodes.</p></details>
        <details class="faq-item"><summary class="faq-q">Can I return my order?</summary><p class="faq-a">Yes — 30-day hassle-free returns. Items must be unworn, in original packaging with tags attached.</p></details>
        <details class="faq-item"><summary class="faq-q">Do you offer Cash on Delivery?</summary><p class="faq-a">Yes! COD is available for all orders across India. No extra charges.</p></details>
        <details class="faq-item"><summary class="faq-q">How do I track my order?</summary><p class="faq-a">You'll receive a tracking link via SMS and email once shipped. You can also check your account dashboard anytime.</p></details>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Get In Touch"},
    {"type":"text","id":"line1","label":"Title line 1","default":"TALK TO"},
    {"type":"text","id":"line2","label":"Title line 2 (orange)","default":"US."},
    {"type":"textarea","id":"subtitle","label":"Subtitle"},
    {"type":"header","content":"Contact Info"},
    {"type":"text","id":"email","label":"Email","default":"hello@urbanzole.in"},
    {"type":"text","id":"phone","label":"Phone","default":"+91 98765 43210"},
    {"type":"text","id":"phone_hours","label":"Phone hours","default":"Mon–Sat, 10am–7pm IST"},
    {"type":"text","id":"whatsapp","label":"WhatsApp (with country code)","default":"+919876543210"},
    {"type":"textarea","id":"address","label":"Address"},
    {"type":"header","content":"Hours"},
    {"type":"text","id":"h_weekday","label":"Mon–Fri","default":"10:00 AM – 7:00 PM"},
    {"type":"text","id":"h_sat","label":"Saturday","default":"10:00 AM – 5:00 PM"},
    {"type":"text","id":"h_sun","label":"Sunday","default":"Closed"}
  ],
  "presets":[{"name":"Contact Page"}]
}
{% endschema %}
